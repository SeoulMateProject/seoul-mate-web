// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(cuid())
  supabaseUserId  String   @unique
  email           String   @unique
  name            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile         Profile?
  diaries         Diary[]
  diaryLikes      DiaryLike[]
  diaryScraps     DiaryScrap[]
  placeLikes      PlaceLike[]
  placeLists      PlaceList[]
}

model Profile {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String   @unique

  nickname    String?
  bio         String?
  city        String?
  interests   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Place {
  id              String   @id @default(cuid())
  externalId      String?  @unique
  name            String
  district        String?
  address         String?
  newAddress      String?
  phone           String?
  website         String?
  openingHours    String?
  openDays        String?
  closedDays      String?
  transportInfo   String?
  tags            String[]
  accessibility   String?

  diaries         Diary[]
  placeLikes      PlaceLike[]
  placeListItems  PlaceListItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Diary {
  id          String      @id @default(cuid())
  user        User        @relation(fields: [userId], references: [id])
  userId      String
  place       Place       @relation(fields: [placeId], references: [id])
  placeId     String

  title       String
  content     String
  likeCount   Int         @default(0)

  likes       DiaryLike[]
  scraps      DiaryScrap[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model DiaryLike {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  diary     Diary    @relation(fields: [diaryId], references: [id])
  diaryId   String

  createdAt DateTime @default(now())

  @@unique([userId, diaryId])
}

model DiaryScrap {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  diary     Diary    @relation(fields: [diaryId], references: [id])
  diaryId   String

  createdAt DateTime @default(now())

  @@unique([userId, diaryId])
}

model PlaceLike {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  place     Place    @relation(fields: [placeId], references: [id])
  placeId   String

  createdAt DateTime @default(now())

  @@unique([userId, placeId])
}

model PlaceList {
  id          String          @id @default(cuid())
  user        User            @relation(fields: [userId], references: [id])
  userId      String

  title       String
  description String?

  items       PlaceListItem[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model PlaceListItem {
  id          String     @id @default(cuid())
  placeList   PlaceList  @relation(fields: [placeListId], references: [id])
  placeListId String
  place       Place      @relation(fields: [placeId], references: [id])
  placeId     String

  order       Int

  createdAt   DateTime   @default(now())

  @@unique([placeListId, placeId])
}
